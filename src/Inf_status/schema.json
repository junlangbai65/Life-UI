{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "default": {},
      "type": "object",
      "properties": {
        "日期与时间": {
          "type": "string"
        },
        "天气": {
          "type": "string"
        },
        "地点": {
          "type": "string"
        }
      }
    },
    "角色": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string",
        "description": "角色名"
      },
      "additionalProperties": {
        "default": {
          "姓名": "",
          "上身": "",
          "下身": "",
          "鞋袜": "",
          "姿态": "",
          "感染进程": 0,
          "性欲": 0,
          "感染状态": "未感染"
        },
        "type": "object",
        "properties": {
          "姓名": {
            "type": "string"
          },
          "上身": {
            "type": "string"
          },
          "下身": {
            "type": "string"
          },
          "鞋袜": {
            "type": "string"
          },
          "姿态": {
            "type": "string"
          },
          "感染进程": {
            "type": "number"
          },
          "性欲": {
            "type": "number"
          },
          "感染状态": {
            "default": "未感染",
            "type": "string",
            "enum": [
              "未感染",
              "感染中",
              "已感染"
            ]
          }
        }
      }
    }
  }
}